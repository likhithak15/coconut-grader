import sqlite3
import os

DB_PATH = os.path.join(os.path.dirname(__file__), "..", "coconut.db")


def get_db():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


def init_db():
    conn = get_db()
    conn.execute("""
        CREATE TABLE IF NOT EXISTS assessments (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            filename TEXT NOT NULL,
            grade TEXT NOT NULL,
            confidence REAL NOT NULL,
            details TEXT,
            image_data TEXT,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    """)
    conn.commit()
    conn.close()


def save_assessment(filename: str, grade: str, confidence: float, details: str, image_data: str):
    conn = get_db()
    cursor = conn.execute(
        "INSERT INTO assessments (filename, grade, confidence, details, image_data) VALUES (?, ?, ?, ?, ?)",
        (filename, grade, confidence, details, image_data),
    )
    conn.commit()
    row_id = cursor.lastrowid
    conn.close()
    return row_id


def get_history(limit: int = 50):
    conn = get_db()
    rows = conn.execute(
        "SELECT * FROM assessments ORDER BY created_at DESC LIMIT ?", (limit,)
    ).fetchall()
    conn.close()
    return [dict(r) for r in rows]


def delete_assessment(assessment_id: int):
    conn = get_db()
    conn.execute("DELETE FROM assessments WHERE id = ?", (assessment_id,))
    conn.commit()
    conn.close()
